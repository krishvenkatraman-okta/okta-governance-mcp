# ==============================================================================
# Okta Configuration
# ==============================================================================

# Okta domain (e.g., your-domain.okta.com)
NEXT_PUBLIC_OKTA_DOMAIN=your-domain.okta.com

# Custom authorization server ID (for ID-JAG → access token exchange)
# Default: "default" (corresponds to /oauth2/default)
NEXT_PUBLIC_OKTA_CUSTOM_AUTH_SERVER_ID=default

# ==============================================================================
# USER OAuth Client (for user authentication and access token exchange)
# ==============================================================================
#
# This is the OAuth 2.0 application that end users log into.
# Used for:
#   1. User authentication (OIDC + PKCE flow)
#   2. Access token exchange (ID-JAG → access token)
#
# Client type: Public (SPA/PKCE) or Confidential (web app with secret)

# User OAuth client ID (required)
NEXT_PUBLIC_OKTA_USER_OAUTH_CLIENT_ID=0oa...

# User OAuth client secret (optional, server-side only)
# Only required if using a confidential web app client (not SPA/PKCE)
# IMPORTANT: Do NOT prefix with NEXT_PUBLIC_ (would expose to browser)
# OKTA_USER_OAUTH_CLIENT_SECRET=...

# ==============================================================================
# AGENT OAuth Client (for ID-JAG exchange ONLY)
# ==============================================================================
#
# This is a SEPARATE OAuth 2.0 client registered for the AI agent.
# Used ONLY for:
#   - ID-JAG exchange (ID token → ID-JAG)
#
# Client type: Confidential with private_key_jwt authentication
# Authentication: Signed client assertion (JWT signed with agent private key)

# Agent OAuth client ID (required, different from user client)
NEXT_PUBLIC_OKTA_AGENT_CLIENT_ID=0oa...

# Agent identifier (required)
NEXT_PUBLIC_OKTA_AGENT_ID=agent-...

# Agent signing key ID (kid) - used in JWT header (required)
NEXT_PUBLIC_OKTA_AGENT_KEY_ID=kid-...

# Agent private key (server-side only - never exposed to browser)
# IMPORTANT: Do NOT prefix with NEXT_PUBLIC_ (would expose to browser)
#
# Option 1: Private key as JWK (JSON string)
# AGENT_PRIVATE_KEY_JWK={"kty":"RSA","kid":"...","n":"...","e":"...","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"..."}
#
# Option 2: Private key file path (server-side)
# AGENT_PRIVATE_KEY_PATH=/path/to/agent-private-key.pem

# ==============================================================================
# OAuth Configuration
# ==============================================================================

# OAuth redirect URI (for OIDC callback)
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ==============================================================================
# MCP Server Configuration
# ==============================================================================

# MCP backend base URL (hosted MCP resource server)
NEXT_PUBLIC_MCP_BASE_URL=http://localhost:3002

# ==============================================================================
# Session Configuration
# ==============================================================================

# Session secret (generate a random string)
# Use: openssl rand -base64 32
SESSION_SECRET=generate-a-random-secret-string-here

# ==============================================================================
# Environment
# ==============================================================================

NODE_ENV=development

# ==============================================================================
# IMPORTANT NOTES
# ==============================================================================
#
# Two OAuth Clients:
# ------------------
# This application uses TWO separate OAuth clients:
#
#   1. USER OAuth Client:
#      - Purpose: User authentication and access token exchange
#      - Used in: /api/auth/start, /api/auth/callback, /api/token/access-token
#      - Type: Public (PKCE) or Confidential (with secret)
#
#   2. AGENT OAuth Client:
#      - Purpose: ID-JAG exchange ONLY
#      - Used in: /api/token/id-jag
#      - Type: Confidential with private_key_jwt (signed client assertion)
#      - Requires: Private key for signing
#
# Authorization Server Usage:
# ---------------------------
# - ORG auth server (/oauth2/v1/...) is used for:
#   1. OIDC + PKCE user authentication (USER client)
#   2. ID token → ID-JAG exchange (AGENT client with signed assertion)
#
# - CUSTOM auth server (/oauth2/{serverId}/v1/...) is used for:
#   3. ID-JAG → access token exchange (USER client)
#
# Client Authentication Methods:
# -------------------------------
# - User authentication: PKCE (no secret required)
# - ID-JAG exchange: private_key_jwt (signed client assertion, no secret required)
# - Access token exchange: client_id only (no secret required for public clients)
#
# Private Key Security:
# ---------------------
# - AGENT_PRIVATE_KEY_JWK and AGENT_PRIVATE_KEY_PATH are server-side only
# - OKTA_USER_OAUTH_CLIENT_SECRET is server-side only
# - Do NOT prefix server-side secrets with NEXT_PUBLIC_
# - Never expose private keys or secrets to browser/client
#
