# Server Configuration
NODE_ENV=development
SERVER_MODE=mrs  # 'mas' or 'mrs'
MAS_PORT=3000
MRS_PORT=3001

# MAS Configuration
MAS_BASE_URL=http://localhost:3000
MAS_JWT_PRIVATE_KEY_PATH=./keys/mas-private-key.pem
MAS_JWT_PUBLIC_KEY_PATH=./keys/mas-public-key.pem
MAS_JWT_ALGORITHM=RS256
MAS_TOKEN_EXPIRY=3600  # seconds

# MRS Configuration
MRS_BASE_URL=http://localhost:3001
MRS_SERVER_NAME=okta-governance-mcp
MRS_SERVER_VERSION=1.0.0

# Okta Service App Configuration
# For OAuth client credentials flow with private_key_jwt
#
# Setup:
# 1. Create service app in Okta Admin Console
# 2. Enable "Client Credentials" grant type
# 3. Set "Client authentication" to "Public key / Private key"
# 4. Upload public key and note the kid (key ID)
# 5. Assign required OAuth scopes (grant admin consent)
# 6. Generate private key locally and reference path here
#
OKTA_DOMAIN=your-domain.okta.com
OKTA_CLIENT_ID=0oa...  # Service app client ID

# Path to private key file (PEM format, RS256)
OKTA_PRIVATE_KEY_PATH=./keys/okta-private-key.pem

# Key ID from Okta (optional but recommended for key rotation)
# Find this in Admin Console > Applications > [Your App] > General > Client Credentials
OKTA_PRIVATE_KEY_KID=your-key-id

# Token endpoint (must use org authorization server, not custom AS)
# Default: https://{OKTA_DOMAIN}/oauth2/v1/token
OKTA_TOKEN_URL=https://your-domain.okta.com/oauth2/v1/token

# Default OAuth scopes (space-separated)
# Used when no specific scopes are requested
# Customize based on your service app's granted scopes
OKTA_SCOPES_DEFAULT=okta.apps.read okta.users.read okta.groups.read

# ID-JAG Validation
ID_JAG_ISSUER=https://your-domain.okta.com/oauth2/default
ID_JAG_AUDIENCE=api://mcp-governance
ID_JAG_JWKS_URI=https://your-domain.okta.com/oauth2/default/v1/keys

# MCP Token Configuration
MCP_TOKEN_AUDIENCE=mcp://okta-governance-mrs
MCP_TOKEN_ISSUER=mcp://okta-governance-mas

# Logging
LOG_LEVEL=info  # error, warn, info, debug, trace

# Feature Flags
ENABLE_AUDIT_LOGGING=true
ENABLE_POSTMAN_CATALOG=true
