# Server Configuration
NODE_ENV=development
SERVER_MODE=mrs  # 'mas' or 'mrs'
MAS_PORT=3000
MRS_PORT=3001

# MAS Configuration
MAS_BASE_URL=http://localhost:3000
MAS_JWT_PRIVATE_KEY_PATH=./keys/mas-private-key.pem
MAS_JWT_PUBLIC_KEY_PATH=./keys/mas-public-key.pem
MAS_JWT_ALGORITHM=RS256
MAS_TOKEN_EXPIRY=3600  # seconds

# MRS Configuration
MRS_BASE_URL=http://localhost:3001
MRS_SERVER_NAME=okta-governance-mcp
MRS_SERVER_VERSION=1.0.0

# Okta Configuration
OKTA_DOMAIN=your-domain.okta.com
OKTA_ISSUER=https://your-domain.okta.com/oauth2/default
OKTA_CLIENT_ID=your-service-app-client-id
OKTA_PRIVATE_KEY_PATH=./keys/okta-private-key.pem
OKTA_TOKEN_URL=https://your-domain.okta.com/oauth2/v1/token

# ID-JAG Validation
ID_JAG_ISSUER=https://your-domain.okta.com/oauth2/default
ID_JAG_AUDIENCE=api://mcp-governance
ID_JAG_JWKS_URI=https://your-domain.okta.com/oauth2/default/v1/keys

# MCP Token Configuration
MCP_TOKEN_AUDIENCE=mcp://okta-governance-mrs
MCP_TOKEN_ISSUER=mcp://okta-governance-mas

# Logging
LOG_LEVEL=info  # error, warn, info, debug, trace

# Feature Flags
ENABLE_AUDIT_LOGGING=true
ENABLE_POSTMAN_CATALOG=true
