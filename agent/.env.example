# MCP Server connection
MCP_SERVER_URL=https://governance-mcp.supersafe-ai.io
MCP_ACCESS_TOKEN=                    # Fallback token (used when SSO is disabled)

# Bedrock
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Agent server
AGENT_PORT=3100
SESSION_SECRET=generate-a-random-secret

# Okta SSO (set both to enable SSO; omit to run without auth)
OKTA_ISSUER=https://your-org.oktapreview.com
OKTA_AGENT_CLIENT_ID=your-oidc-client-id
OKTA_AGENT_CLIENT_SECRET=your-oidc-client-secret
OKTA_SCOPES=openid profile email
AGENT_CALLBACK_URL=http://localhost:3100/auth/callback
